[gd_scene format=3 uid="uid://ohp0txv3seb8"]

[sub_resource type="GDScript" id="GDScript_q1fsa"]
script/source = "extends Node

var cuerpo_actual: int = 0
var skins_por_jugador: Dictionary = {}

# Nodos reales — los recibe el player al inicializarse
var _sprites_por_jugador: Dictionary = {}  # { peer_id: [light, dark] }
var _sprite_activo: Dictionary = {}

func inicializar(peer_id: int, cuerpos: Array) -> void:
	_sprites_por_jugador[peer_id] = cuerpos
	_aplicar_cuerpo(peer_id, skins_por_jugador.get(peer_id, 0))

func _aplicar_cuerpo(peer_id: int, index: int) -> void:
	if not _sprites_por_jugador.has(peer_id): return
	var cuerpos = _sprites_por_jugador[peer_id]
	if cuerpos.is_empty() or index >= cuerpos.size(): return
	for c in cuerpos:
		if c != null: c.visible = false
	if cuerpos[index] != null:
		cuerpos[index].visible = true
		_sprite_activo[peer_id] = cuerpos[index]

func cambiar_cuerpo(peer_id: int, index: int) -> void:
	var anim = \"idle\"
	if _sprite_activo.has(peer_id) and _sprite_activo[peer_id] != null:
		anim = _sprite_activo[peer_id].animation
	skins_por_jugador[peer_id] = index
	_aplicar_cuerpo(peer_id, index)
	play(peer_id, anim)

func play(peer_id: int, anim: String) -> void:
	if _sprite_activo.has(peer_id) and _sprite_activo[peer_id] != null:
		_sprite_activo[peer_id].play(anim)

func flip(peer_id: int, hacia_izquierda: bool) -> void:
	if _sprite_activo.has(peer_id) and _sprite_activo[peer_id] != null:
		_sprite_activo[peer_id].flip_h = hacia_izquierda
		
func modulate_damage(peer_id: int) -> void:
	if _sprite_activo.has(peer_id):
		_sprite_activo[peer_id].modulate = Color(10, 1, 1)

func modulate_reset(peer_id: int) -> void:
	if _sprite_activo.has(peer_id):
		_sprite_activo[peer_id].modulate = Color(1, 1, 1)
"

[node name="Skins" type="Node2D" unique_id=1073997655]
